{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Jwt": {
    "Key": "",
    "Issuer": "LocalHiringPlatform",
    "Audience": "LocalHiringPlatformUsers",
    "ExpiryMinutes": 60
  },

  "Gemini": {
    "ApiKey": "",
    "GeminiEndpoint": "https://generativelanguage.googleapis.com/v1beta/models/gemini-3.6-flash:generateContent?key="
  },
  "Resend": {
    "ApiKey": "",
    "FromEmail": "no-reply@getlocalhire.com",
    "FromName": "LocalHire AI"
  },
  "Application": {
    "FrontendUrl": "http://localhost:5173",
    "PromptFolder": "Prompts",
    "UseRedis": true
  },
  "Msg91": {
    "BaseUrl": "https://api.msg91.com",
    "AuthKey": "",
    "WidgetAuthToken": "",
    "WidgetId": "",
    "TemplateId": "",
    "VerifyAccessTokenEndpoint": "/api/v5/widget/verifyAccessToken"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "Enabled": true
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "restrictedToMinimumLevel": "Information",
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ]
  }
}

